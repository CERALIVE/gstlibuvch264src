diff --git a/src/device.c b/src/device.c
index f8113cc..cfb5eee 100644
--- a/src/device.c
+++ b/src/device.c
@@ -296,6 +296,11 @@ uvc_error_t uvc_wrap(
     return err;
   }
 
+  /* Auto-detach any kernel driver (e.g. uvcvideo) when we claim interfaces.
